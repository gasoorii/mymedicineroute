}

/* ─── SMALL MOBILE ───────────────────────────────────── */
@media (max-width: 480px) {
  h1 { font-size: 32px !important; letter-spacing: -1.5px !important; }
  h2 { font-size: 24px !important; }
  .badge-red { font-size: 11px !important; }
}

@keyframes blobMove1 {
  from { transform: translate(0px, 0px) scale(1); }
  to   { transform: translate(60px, 40px) scale(1.1); }
}
@keyframes blobMove2 {
  from { transform: translate(0px, 0px) scale(1); }
  to   { transform: translate(-50px, 60px) scale(1.15); }
}
@keyframes blobMove3 {
  from { transform: translate(0px, 0px) scale(1); }
  to   { transform: translate(40px, -50px) scale(0.95); }
}
