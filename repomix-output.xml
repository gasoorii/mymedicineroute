    <path d="M10 3v5.6a3 3 0 0 1-.8 2.1l-4.2 4.6a5 5 0 0 0 0 6.7h14a5 5 0 0 0 0-6.7l-4.2-4.6a3 3 0 0 1-.8-2.1V3" />
