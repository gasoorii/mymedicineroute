<file path="app/globals.css">
/* Font loaded via next/font in layout.tsx — no external request needed */

* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

:root {
  --primary-red: #E11D48;
  --primary-hover: #BE123C;
  --soft-red: rgba(225,29,72,0.12);
  --bg: #18191b;
  --bg-section: #1c1d1f;
  --bg-card: rgba(255,255,255,0.04);
  --border: rgba(255,255,255,0.08);
  --text-primary: #f1f5f9;
  --text-secondary: #94a3b8;
}

html {
  scroll-behavior: smooth;
}

body {
  font-family: 'Inter', -apple-system, sans-serif;
  background: var(--bg);
  color: var(--text-primary);
  overflow-x: hidden;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

@keyframes reveal {
  from { opacity: 0; transform: translateY(24px); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes pulse-red {
  0% { box-shadow: 0 0 0 0 rgba(225, 29, 72, 0.4); }
  70% { box-shadow: 0 0 0 10px rgba(225, 29, 72, 0); }
  100% { box-shadow: 0 0 0 0 rgba(225, 29, 72, 0); }
}

@keyframes heartbeat {
  0% { transform: scale(1); }
  14% { transform: scale(1.06); }
  28% { transform: scale(1); }
  42% { transform: scale(1.04); }
  70% { transform: scale(1); }
  100% { transform: scale(1); }
}

.animate-reveal {
  animation: reveal 0.6s ease-out forwards;
}

.nav-item {
  text-decoration: none;
  color: var(--text-secondary);
  font-weight: 500;
  transition: color 0.2s ease;
}
.nav-item:hover { color: var(--primary-red); }

.btn-red {
  background: var(--primary-red);
  color: white;
  padding: 12px 24px;
  border-radius: 999px;
  text-decoration: none;
  font-weight: 600;
  transition: all 0.2s ease;
  box-shadow: 0 4px 15px rgba(225, 29, 72, 0.25);
  display: inline-block;
}
.btn-red:hover {
  background: var(--primary-hover);
  transform: translateY(-2px);
  box-shadow: 0 8px 25px rgba(225, 29, 72, 0.35);
}

.btn-ghost {
  background: transparent;
  color: var(--text-primary);
  padding: 12px 24px;
  border-radius: 999px;
  text-decoration: none;
  font-weight: 700;
  border: 1.5px solid rgba(255,255,255,0.15);
  transition: all 0.2s ease;
  display: inline-block;
}
.btn-ghost:hover {
  border-color: var(--primary-red);
  color: var(--primary-red);
  transform: translateY(-2px);
}

.glass-card {
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(255,255,255,0.08);
  transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
}
.glass-card:hover {
  transform: translateY(-6px);
  border-color: rgba(225, 29, 72, 0.3);
  box-shadow: 0 16px 32px rgba(0,0,0,0.25);
}

.badge-red {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: rgba(225,29,72,0.12);
  color: var(--primary-red);
  font-size: 12px;
  font-weight: 700;
  padding: 6px 16px;
  border-radius: 999px;
  border: 1px solid rgba(225, 29, 72, 0.2);
}

.pulse-dot {
  width: 6px;
  height: 6px;
  background: var(--primary-red);
  border-radius: 50%;
  animation: pulse-red 2s infinite;
}

.heart-bg {
  animation: heartbeat 1.8s ease-in-out infinite;
}

.mono-icon {
  width: 52px;
  height: 52px;
  object-fit: contain;
  filter: grayscale(1) invert(1) contrast(1.2) brightness(1.1);
}

/* Scroll reveal */
.sr {
  opacity: 0;
  transform: translateY(24px);
  transition: opacity 0.5s ease, transform 0.5s ease;
}
.sr.visible {
  opacity: 1;
  transform: translateY(0);
}
.sr-delay-1 { transition-delay: 0.08s; }
.sr-delay-2 { transition-delay: 0.16s; }
.sr-delay-3 { transition-delay: 0.24s; }
.sr-delay-4 { transition-delay: 0.32s; }

/* Nav */
.nav-desktop { display: flex; }
.nav-mobile { display: none !important; }

/* ─── MOBILE ─────────────────────────────────────────── */
@media (max-width: 768px) {
  .nav-desktop { display: none !important; }
  .nav-mobile { display: flex !important; }
  nav { padding: 0 20px !important; }

  section { padding: 60px 20px !important; }

  h1 {
    font-size: 38px !important;
    letter-spacing: -2px !important;
    line-height: 1.1 !important;
  }
  h2 { font-size: 28px !important; letter-spacing: -1px !important; }
  h3 { font-size: 22px !important; }

  .hero-btns {
    flex-direction: column !important;
    align-items: center !important;
    gap: 12px !important;
  }
  .hero-btns a {
    width: 100% !important;
    max-width: 280px !important;
    text-align: center !important;
  }

  .glass-card { padding: 24px !important; }

  .mobile-grid {
    grid-template-columns: 1fr !important;
  }

  .mobile-grid-2col {
    grid-template-columns: 1fr 1fr !important;
  }

  footer {
    flex-direction: column !important;
    gap: 12px !important;
    text-align: center !important;
    padding: 32px 20px !important;
